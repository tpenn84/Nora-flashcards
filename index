<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Nora's Ocean Study Cards 🌊</title>
<link href="https://fonts.googleapis.com/css2?family=Fredoka+One&family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet">
<style>
  :root {
    --deep: #0a1628;
    --ocean: #0d3b6e;
    --mid: #1565c0;
    --wave: #29b6f6;
    --foam: #e0f7fa;
    --coral: #ff6b6b;
    --sun: #ffd93d;
    --green: #6bcb77;
    --white: #ffffff;
  }

- { box-sizing: border-box; margin: 0; padding: 0; }

body {
min-height: 100vh;
background: linear-gradient(160deg, var(–deep) 0%, var(–ocean) 50%, var(–mid) 100%);
font-family: ‘Nunito’, sans-serif;
display: flex;
flex-direction: column;
align-items: center;
padding: 20px 16px 40px;
overflow-x: hidden;
position: relative;
}

.bubble {
position: fixed;
border-radius: 50%;
background: rgba(41, 182, 246, 0.1);
animation: rise linear infinite;
pointer-events: none;
}
@keyframes rise {
0% { transform: translateY(110vh); opacity: 0.5; }
100% { transform: translateY(-10vh); opacity: 0; }
}

header {
text-align: center;
margin-bottom: 18px;
z-index: 1;
}

.title {
font-family: ‘Fredoka One’, cursive;
font-size: clamp(1.8rem, 6vw, 2.8rem);
color: var(–sun);
text-shadow: 0 3px 20px rgba(255,217,61,0.4);
}

.subtitle {
color: var(–wave);
font-size: 0.85rem;
font-weight: 800;
margin-top: 2px;
letter-spacing: 2px;
text-transform: uppercase;
}

.progress-bar-wrap {
width: min(520px, 92vw);
background: rgba(255,255,255,0.1);
border-radius: 999px;
height: 8px;
margin-bottom: 10px;
z-index: 1;
overflow: hidden;
}
.progress-bar {
height: 100%;
background: linear-gradient(90deg, var(–wave), var(–sun));
border-radius: 999px;
transition: width 0.5s ease;
}

.card-counter {
color: rgba(255,255,255,0.5);
font-size: 0.8rem;
font-weight: 800;
margin-bottom: 14px;
z-index: 1;
letter-spacing: 1px;
}

.question-card {
width: min(520px, 92vw);
background: linear-gradient(135deg, #1a237e 0%, var(–ocean) 70%, #0077b6 100%);
border: 2px solid rgba(41,182,246,0.25);
border-radius: 24px;
padding: 24px 24px 20px;
box-shadow: 0 20px 60px rgba(0,0,0,0.5);
z-index: 1;
position: relative;
}

.category-badge {
display: inline-block;
background: rgba(255,255,255,0.12);
color: rgba(255,255,255,0.7);
font-size: 0.62rem;
font-weight: 800;
letter-spacing: 2px;
text-transform: uppercase;
padding: 4px 10px;
border-radius: 999px;
margin-bottom: 14px;
}

.question-header {
display: flex;
align-items: flex-start;
gap: 12px;
margin-bottom: 20px;
}

.q-emoji { font-size: 2rem; flex-shrink: 0; }

.question-text {
font-family: ‘Fredoka One’, cursive;
font-size: clamp(1rem, 3.5vw, 1.3rem);
color: var(–white);
line-height: 1.4;
}

.type-tag {
position: absolute;
top: 18px;
right: 18px;
font-size: 0.6rem;
font-weight: 800;
letter-spacing: 1.5px;
text-transform: uppercase;
padding: 3px 8px;
border-radius: 999px;
color: var(–deep);
}
.type-tag.mc { background: var(–sun); }
.type-tag.tf { background: var(–wave); }

.options {
display: flex;
flex-direction: column;
gap: 10px;
margin-top: 4px;
}

.option-btn {
background: rgba(255,255,255,0.08);
border: 2px solid rgba(255,255,255,0.15);
border-radius: 14px;
padding: 12px 16px;
color: var(–white);
font-family: ‘Nunito’, sans-serif;
font-size: clamp(0.85rem, 2.8vw, 1rem);
font-weight: 700;
cursor: pointer;
text-align: left;
display: flex;
align-items: center;
gap: 10px;
transition: background 0.15s, border-color 0.15s, transform 0.1s;
}
.option-btn:hover:not(:disabled) {
background: rgba(255,255,255,0.16);
border-color: rgba(255,255,255,0.35);
transform: translateX(3px);
}
.option-btn:disabled { cursor: default; }
.option-btn.correct {
background: rgba(107,203,119,0.25);
border-color: var(–green);
color: #a5d6a7;
}
.option-btn.wrong {
background: rgba(255,107,107,0.2);
border-color: var(–coral);
color: #ef9a9a;
}
.option-btn.reveal-correct {
background: rgba(107,203,119,0.15);
border-color: rgba(107,203,119,0.5);
}

.option-letter {
width: 26px;
height: 26px;
border-radius: 50%;
background: rgba(255,255,255,0.15);
display: flex;
align-items: center;
justify-content: center;
font-size: 0.75rem;
font-weight: 800;
flex-shrink: 0;
}
.correct .option-letter { background: var(–green); color: var(–deep); }
.wrong .option-letter { background: var(–coral); color: white; }
.reveal-correct .option-letter { background: rgba(107,203,119,0.5); }

.feedback {
margin-top: 14px;
border-radius: 14px;
padding: 12px 16px;
font-size: 0.88rem;
font-weight: 700;
display: none;
align-items: flex-start;
gap: 10px;
line-height: 1.4;
}
.feedback.show { display: flex; }
.feedback.correct-fb {
background: rgba(107,203,119,0.15);
color: #a5d6a7;
border: 1px solid rgba(107,203,119,0.3);
}
.feedback.wrong-fb {
background: rgba(255,107,107,0.12);
color: #ef9a9a;
border: 1px solid rgba(255,107,107,0.25);
}
.feedback-icon { font-size: 1.3rem; flex-shrink: 0; margin-top: 1px; }

.controls {
display: flex;
gap: 12px;
margin-top: 20px;
z-index: 1;
}

.btn {
font-family: ‘Nunito’, sans-serif;
font-weight: 800;
font-size: 0.9rem;
border: none;
border-radius: 999px;
padding: 12px 26px;
cursor: pointer;
transition: transform 0.15s, box-shadow 0.15s;
}
.btn:active { transform: scale(0.96); }

.btn-next {
background: linear-gradient(135deg, var(–wave), #0288d1);
color: var(–white);
box-shadow: 0 8px 24px rgba(41,182,246,0.35);
}
.btn-next:disabled {
opacity: 0.35;
cursor: default;
transform: none !important;
}
.btn-shuffle {
background: rgba(255,255,255,0.1);
color: var(–white);
border: 2px solid rgba(255,255,255,0.2);
}
.btn-shuffle:hover { background: rgba(255,255,255,0.18); }

.btn-mix {
background: linear-gradient(135deg, #7c3aed, #a855f7);
color: var(–white);
box-shadow: 0 8px 24px rgba(124,58,237,0.4);
}
.btn-mix:hover { box-shadow: 0 10px 30px rgba(124,58,237,0.6); transform: translateY(-1px); }
.btn-mix:disabled { opacity: 0.5; cursor: default; transform: none !important; }

.mix-toast {
position: fixed;
top: 20px;
left: 50%;
transform: translateX(-50%) translateY(-80px);
background: linear-gradient(135deg, #7c3aed, #a855f7);
color: white;
font-family: ‘Nunito’, sans-serif;
font-weight: 800;
font-size: 0.9rem;
padding: 12px 24px;
border-radius: 999px;
box-shadow: 0 8px 30px rgba(124,58,237,0.5);
z-index: 999;
transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
white-space: nowrap;
}
.mix-toast.show { transform: translateX(-50%) translateY(0); }

.score-display {
z-index: 1;
margin-top: 14px;
color: rgba(255,255,255,0.5);
font-size: 0.82rem;
font-weight: 700;
letter-spacing: 1px;
}
.score-display span { color: var(–sun); }

.round-complete {
display: none;
flex-direction: column;
align-items: center;
z-index: 10;
text-align: center;
padding: 20px;
}
.round-complete.show { display: flex; }
.trophy { font-size: 5rem; animation: bounce 0.6s ease infinite alternate; }
@keyframes bounce { from { transform: translateY(0); } to { transform: translateY(-12px); } }
.round-title { font-family: ‘Fredoka One’, cursive; font-size: 2.2rem; color: var(–sun); margin-top: 16px; }
.round-score { font-size: 1.1rem; color: var(–foam); font-weight: 700; margin-top: 10px; line-height: 1.6; white-space: pre-line; }
.btn-restart {
margin-top: 24px;
background: linear-gradient(135deg, var(–sun), #ffb300);
color: var(–deep);
font-family: ‘Nunito’, sans-serif;
font-weight: 800;
font-size: 1rem;
border: none;
border-radius: 999px;
padding: 14px 36px;
cursor: pointer;
box-shadow: 0 8px 24px rgba(255,217,61,0.4);
}

.wave-deco {
position: fixed;
bottom: 0; left: 0;
width: 100%;
opacity: 0.1;
pointer-events: none;
}
</style>

</head>
<body>

<svg class="wave-deco" viewBox="0 0 1440 120" fill="none" xmlns="http://www.w3.org/2000/svg">
  <path d="M0,60 C240,120 480,0 720,60 C960,120 1200,0 1440,60 L1440,120 L0,120 Z" fill="white"/>
</svg>

<header>
  <div class="title">🌊 Nora's Ocean Cards</div>
  <div class="subtitle">5.6 Ocean Study Guide</div>
</header>

<div id="mainContent" style="display:flex;flex-direction:column;align-items:center;width:100%">
  <div class="progress-bar-wrap"><div class="progress-bar" id="progressBar"></div></div>
  <div class="card-counter" id="cardCounter">Question 1 of 20</div>

  <div class="question-card">
    <div class="category-badge" id="categoryBadge">Ocean Features</div>
    <div class="type-tag mc" id="typeTag">MULTIPLE CHOICE</div>
    <div class="question-header">
      <div class="q-emoji" id="cardEmoji">🌊</div>
      <div class="question-text" id="questionText">Loading...</div>
    </div>
    <div class="options" id="optionsContainer"></div>
    <div class="feedback" id="feedback">
      <div class="feedback-icon" id="feedbackIcon"></div>
      <div id="feedbackText"></div>
    </div>
  </div>

  <div class="controls">
    <button class="btn btn-shuffle" onclick="shuffleCards()">🔀 Shuffle</button>
    <button class="btn btn-mix" id="mixBtn" onclick="mixDeck()">✨ Mix Deck</button>
    <button class="btn btn-next" id="nextBtn" onclick="nextCard()" disabled>Next →</button>
  </div>

  <div class="score-display">⭐ Correct: <span id="correctCount">0</span> &nbsp;|&nbsp; 💦 Wrong: <span id="wrongCount">0</span></div>
</div>

<div class="round-complete" id="roundComplete">
  <div class="trophy">🏆</div>
  <div class="round-title">Round Complete!</div>
  <div class="round-score" id="roundScoreText"></div>
  <button class="btn-restart" onclick="restartRound()">🔄 Play Again!</button>
</div>

<div class="mix-toast" id="mixToast">✨ New questions mixed in!</div>

<script>
for (let i = 0; i < 10; i++) {
  const b = document.createElement('div');
  b.className = 'bubble';
  const size = 10 + Math.random() * 40;
  b.style.cssText = `width:${size}px;height:${size}px;left:${Math.random()*100}%;animation-duration:${8+Math.random()*12}s;animation-delay:${Math.random()*8}s`;
  document.body.appendChild(b);
}

const cards = [
  { category:"Ocean Features", emoji:"🌍", type:"tf",
    q:"True or False: Oceans cover about 70% of Earth's surface.",
    options:["True","False"], answer:0,
    explanation:"Correct! Oceans cover approximately 70% of Earth's surface." },
  { category:"Ocean Features", emoji:"🏖️", type:"mc",
    q:"The continental shelf is best described as...",
    options:["A very deep trench near the ocean floor","A shallow, flat area of the ocean floor near continents","The steep drop from the shelf to the deep ocean","A mountain range under the ocean"],
    answer:1, explanation:"The continental shelf is the relatively shallow, flat area near the continents — about 200 meters deep." },
  { category:"Ocean Features", emoji:"📉", type:"mc",
    q:"What comes after the continental shelf as you travel deeper into the ocean?",
    options:["Abyssal Plain","Trench","Continental Slope","Volcanic Island"],
    answer:2, explanation:"The continental slope is the steep drop-off right after the shelf, descending from 200 to about 3,000 meters deep." },
  { category:"Ocean Features", emoji:"🪨", type:"tf",
    q:"True or False: The ocean floor near continents is covered with thick layers of sediment (sand, mud, rock).",
    options:["True","False"], answer:0,
    explanation:"True! Thick layers of sediment — sand, mud, and rock — blanket the continental areas of the ocean floor." },
  { category:"Ocean Features", emoji:"🕳️", type:"mc",
    q:"How deep can ocean trenches reach?",
    options:["About 200 meters","About 1,000 meters","Up to 10,000 meters","Only 500 meters"],
    answer:2, explanation:"Ocean trenches are extremely deep — they can reach up to 10,000 meters!" },
  { category:"Ocean Features", emoji:"🌊", type:"mc",
    q:"The abyssal plain is found at which depth range?",
    options:["0–200 meters","200–1,000 meters","1,000–3,000 meters","4,000–6,000 meters"],
    answer:3, explanation:"The abyssal plain is the flat, deep ocean floor found at 4,000–6,000 meters depth." },
  { category:"Ocean Features", emoji:"🗺️", type:"mc",
    q:"Which list orders ocean floor features correctly from SHALLOWEST to DEEPEST?",
    options:["Shelf → Slope → Rise → Abyssal Plain → Trench","Trench → Slope → Shelf → Rise → Plain","Rise → Shelf → Trench → Slope → Plain","Slope → Shelf → Plain → Rise → Trench"],
    answer:0, explanation:"Correct order shallowest to deepest: Continental Shelf → Slope → Rise → Abyssal Plain → Trench." },
  { category:"Ocean Water", emoji:"💧", type:"mc",
    q:"Ocean water is a complex mixture of dissolved gases and dissolved...",
    options:["Plastics","Solids — especially sodium chloride (salt)","Fresh water","Sand and gravel"],
    answer:1, explanation:"Ocean water contains dissolved gases (air) and dissolved solids — especially sodium chloride, which is salt." },
  { category:"Ocean Water", emoji:"🐠", type:"tf",
    q:"True or False: Marine animals depend on dissolved gases in ocean water to survive.",
    options:["True","False"], answer:0,
    explanation:"True! Marine animals need dissolved oxygen in the ocean water to breathe and survive." },
  { category:"Ocean Water", emoji:"🧂", type:"mc",
    q:"Ocean salinity (saltiness) varies based on evaporation rates AND...",
    options:["Wind speed","Depth of the ocean","Amount of runoff from nearby land","Ocean color"],
    answer:2, explanation:"Salinity varies due to evaporation AND the amount of runoff (fresh water flowing in) from nearby land." },
  { category:"Ocean Motion", emoji:"🌀", type:"mc",
    q:"What are the THREE basic motions of ocean water?",
    options:["Rain, snow, and sleet","Currents, tides, and waves","Evaporation, condensation, and precipitation","Floods, storms, and tsunamis"],
    answer:1, explanation:"The three basic motions of ocean water are currents, tides, and waves." },
  { category:"Ocean Motion", emoji:"🌊", type:"mc",
    q:"Ocean currents like the Gulf Stream are caused by wind patterns and differences in water...",
    options:["Color and clarity","Age and depth","Temperature and salinity (density)","Size and shape of the ocean"],
    answer:2, explanation:"Ocean currents are driven by wind patterns and differences in water density — caused by temperature and salinity differences." },
  { category:"Ocean Motion", emoji:"🧭", type:"tf",
    q:"True or False: Ocean currents can affect navigation routes for ships.",
    options:["True","False"], answer:0,
    explanation:"True! Ocean currents affect the mixing of waters, plant and animal life, AND navigation routes." },
  { category:"Ocean Motion", emoji:"🌙", type:"mc",
    q:"A map showing large circular flow patterns across the globe's oceans is showing...",
    options:["Waves","Tides","Currents","Trenches"],
    answer:2, explanation:"Large circular flow patterns = ocean currents (like the Great Ocean Conveyor Belt / Gulf Stream)." },
  { category:"Ocean Life", emoji:"☀️", type:"mc",
    q:"As ocean depth increases, what happens to temperature AND light?",
    options:["Both increase","Temperature increases, light decreases","Both decrease","Temperature decreases, light increases"],
    answer:2, explanation:"As depth increases: temperature DECREASES and light DECREASES — it becomes very cold and completely dark in the deep ocean." },
  { category:"Ocean Life", emoji:"🔬", type:"tf",
    q:"True or False: Plankton are tiny free-floating organisms that live in water.",
    options:["True","False"], answer:0,
    explanation:"True! Plankton are tiny, free-floating organisms. They can be animal-like (zooplankton) or plant-like (phytoplankton)." },
  { category:"Ocean Life", emoji:"🌿", type:"mc",
    q:"Phytoplankton are critical to life on Earth because they...",
    options:["Eat sharks and large fish","Carry out most of Earth's photosynthesis and produce much of Earth's oxygen","Live only in freshwater rivers","Are the biggest animals in the ocean"],
    answer:1, explanation:"Phytoplankton carry out most of Earth's photosynthesis, produce much of Earth's oxygen, and form the BASE of the ocean food web!" },
  { category:"Ocean Life", emoji:"🦈", type:"mc",
    q:"What is the correct order of the ocean food chain?",
    options:["Shark → Small Fish → Zooplankton → Phytoplankton → Sun","Sun → Zooplankton → Phytoplankton → Small Fish → Shark","Sun → Phytoplankton → Zooplankton → Small Fish → Shark","Phytoplankton → Sun → Shark → Small Fish → Zooplankton"],
    answer:2, explanation:"Sun → Phytoplankton (producer) → Zooplankton → Small Fish → Shark. The sun powers the whole chain!" },
  { category:"Ocean Life", emoji:"🦐", type:"mc",
    q:"Animal-like plankton are called _____, and plant-like plankton are called _____.",
    options:["Phytoplankton and Zooplankton","Zooplankton and Phytoplankton","Bacteria and Algae","Jellyfish and Seaweed"],
    answer:1, explanation:"Animal-like = ZOOplankton (zoo = animals). Plant-like = PHYTOplankton (phyto = plant). Easy memory trick!" },
  { category:"Ocean Life", emoji:"🌱", type:"tf",
    q:"True or False: Phytoplankton form the base of the ocean food web.",
    options:["True","False"], answer:0,
    explanation:"True! Phytoplankton are producers — everything in the ocean food web depends on them starting with sunlight." }
];

let currentIndex = 0, correctCount = 0, wrongCount = 0, answered = false;
let order = [...Array(cards.length).keys()];

function shuffleArray(arr) {
  for (let i = arr.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [arr[i], arr[j]] = [arr[j], arr[i]];
  }
}

function loadCard() {
  answered = false;
  const card = cards[order[currentIndex]];
  document.getElementById('categoryBadge').textContent = card.category;
  document.getElementById('cardEmoji').textContent = card.emoji;
  document.getElementById('questionText').textContent = card.q;
  document.getElementById('cardCounter').textContent = `Question ${currentIndex + 1} of ${cards.length}`;
  document.getElementById('progressBar').style.width = (currentIndex / cards.length * 100) + '%';

  const typeTag = document.getElementById('typeTag');
  typeTag.textContent = card.type === 'tf' ? 'TRUE / FALSE' : 'MULTIPLE CHOICE';
  typeTag.className = 'type-tag ' + card.type;

  const container = document.getElementById('optionsContainer');
  container.innerHTML = '';
  const letters = ['A','B','C','D'];
  card.options.forEach((opt, i) => {
    const btn = document.createElement('button');
    btn.className = 'option-btn';
    btn.innerHTML = `<span class="option-letter">${letters[i]}</span>${opt}`;
    btn.onclick = () => selectAnswer(i, btn, card);
    container.appendChild(btn);
  });

  document.getElementById('feedback').className = 'feedback';
  document.getElementById('nextBtn').disabled = true;
}

function selectAnswer(chosen, btn, card) {
  if (answered) return;
  answered = true;
  document.querySelectorAll('.option-btn').forEach(b => b.disabled = true);

  const fb = document.getElementById('feedback');
  if (chosen === card.answer) {
    btn.classList.add('correct');
    fb.className = 'feedback correct-fb show';
    document.getElementById('feedbackIcon').textContent = '🎉';
    correctCount++;
  } else {
    btn.classList.add('wrong');
    document.querySelectorAll('.option-btn')[card.answer].classList.add('reveal-correct');
    fb.className = 'feedback wrong-fb show';
    document.getElementById('feedbackIcon').textContent = '💡';
    wrongCount++;
  }
  document.getElementById('feedbackText').textContent = card.explanation;
  document.getElementById('correctCount').textContent = correctCount;
  document.getElementById('wrongCount').textContent = wrongCount;
  document.getElementById('nextBtn').disabled = false;
}

function nextCard() {
  if (currentIndex < cards.length - 1) { currentIndex++; loadCard(); }
  else showRoundComplete();
}

function shuffleCards() {
  shuffleArray(order);
  currentIndex = 0; correctCount = 0; wrongCount = 0;
  document.getElementById('correctCount').textContent = 0;
  document.getElementById('wrongCount').textContent = 0;
  loadCard();
}

const altCards = [
  { category:"Ocean Features", emoji:"🌋", type:"tf",
    q:"True or False: A volcanic island can rise from the ocean floor.",
    options:["True","False"], answer:0,
    explanation:"True! Volcanic islands form when underwater volcanoes build up enough material to break the ocean surface." },
  { category:"Ocean Features", emoji:"🗻", type:"mc",
    q:"Which ocean floor feature is the FLATTEST?",
    options:["Continental Shelf","Continental Slope","Abyssal Plain","Ocean Trench"],
    answer:2, explanation:"The Abyssal Plain is the flattest region on Earth — it's a vast, level deep-sea floor at 4,000–6,000 meters." },
  { category:"Ocean Water", emoji:"🌡️", type:"tf",
    q:"True or False: Water temperature affects the salinity of the ocean.",
    options:["True","False"], answer:0,
    explanation:"True! Warmer water evaporates faster, leaving more salt behind and increasing salinity." },
  { category:"Ocean Water", emoji:"🧪", type:"mc",
    q:"What is the main salt found dissolved in ocean water?",
    options:["Baking soda","Sodium chloride (table salt)","Sugar","Calcium"],
    answer:1, explanation:"Sodium chloride — the same as table salt — is the primary dissolved solid in ocean water." },
  { category:"Ocean Motion", emoji:"🌊", type:"mc",
    q:"Which ocean motion is mainly caused by the gravitational pull of the Moon?",
    options:["Waves","Currents","Tides","Runoff"],
    answer:2, explanation:"Tides are caused by the Moon's gravitational pull on Earth's oceans, causing water levels to rise and fall." },
  { category:"Ocean Motion", emoji:"💨", type:"tf",
    q:"True or False: Wind is one of the causes of ocean currents.",
    options:["True","False"], answer:0,
    explanation:"True! Wind patterns drive surface currents across the ocean. The Gulf Stream is a great example." },
  { category:"Ocean Life", emoji:"🌞", type:"mc",
    q:"Why can't phytoplankton live in the very deep ocean?",
    options:["It's too warm down there","There is no sunlight at great depths","The water moves too fast","There's too much salt"],
    answer:1, explanation:"Phytoplankton need sunlight for photosynthesis. Deep ocean has no light, so they live near the surface." },
  { category:"Ocean Life", emoji:"🐳", type:"tf",
    q:"True or False: Zooplankton are plant-like plankton.",
    options:["True","False"], answer:1,
    explanation:"False! ZOOplankton are ANIMAL-like plankton. PHYTOplankton are plant-like. Zoo = animals!" },
  { category:"Ocean Life", emoji:"🍽️", type:"mc",
    q:"In the ocean food chain, what does a small fish eat?",
    options:["Sharks","Phytoplankton","Zooplankton","Seaweed"],
    answer:2, explanation:"Small fish eat zooplankton. The order is: Phytoplankton → Zooplankton → Small Fish → Shark." },
  { category:"Ocean Features", emoji:"📏", type:"mc",
    q:"Approximately how deep is the continental shelf?",
    options:["20 meters","200 meters","2,000 meters","10,000 meters"],
    answer:1, explanation:"The continental shelf extends to about 200 meters depth — it's the shallowest major ocean floor region." },
];

let usingAltDeck = false;

function mixDeck() {
  const btn = document.getElementById('mixBtn');
  btn.disabled = true;
  btn.textContent = '⏳ Mixing...';

  setTimeout(() => {
    const newDeck = usingAltDeck ? [...cards] : [...altCards];
    usingAltDeck = !usingAltDeck;

    // Replace 10 random cards from current deck with new ones
    const mixed = [...cards];
    shuffleArray(newDeck);
    const replaceIndices = [...Array(cards.length).keys()];
    shuffleArray(replaceIndices);
    replaceIndices.slice(0, Math.min(10, newDeck.length)).forEach((ri, i) => {
      mixed[ri] = newDeck[i];
    });

    order = [...Array(mixed.length).keys()];
    shuffleArray(order);

    // Temporarily swap cards array
    cards.splice(0, cards.length, ...mixed);
    currentIndex = 0; correctCount = 0; wrongCount = 0;
    document.getElementById('correctCount').textContent = 0;
    document.getElementById('wrongCount').textContent = 0;
    loadCard();

    btn.disabled = false;
    btn.textContent = '✨ Mix Deck';

    const toast = document.getElementById('mixToast');
    toast.classList.add('show');
    setTimeout(() => toast.classList.remove('show'), 2500);
  }, 600);
}

function showRoundComplete() {
  document.getElementById('mainContent').style.display = 'none';
  document.getElementById('roundComplete').classList.add('show');
  const total = correctCount + wrongCount;
  const pct = total > 0 ? Math.round(correctCount / total * 100) : 0;
  const msg = pct === 100 ? '🌟 Perfect score! You crushed it, Nora!'
    : pct >= 80 ? `🐬 Amazing work! ${pct}% — almost perfect!`
    : pct >= 60 ? `🌊 Good effort! ${pct}% — keep studying!`
    : `🐙 Keep going! ${pct}% — you've got this!`;
  document.getElementById('roundScoreText').textContent = `You got ${correctCount} out of ${total} correct!\n${msg}`;
}

function restartRound() {
  document.getElementById('roundComplete').classList.remove('show');
  document.getElementById('mainContent').style.display = 'flex';
  shuffleCards();
}

shuffleArray(order);
loadCard();
</script>

